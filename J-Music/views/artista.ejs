<%- include('header') %>

<main class="container">
    <h1>Lista de Artistas</h1>
    
    <% if (typeof artistas !== 'undefined' && artistas.length > 0) { %>
        <div class="lista-artistas">
            <% artistas.forEach(artista => { %>
                <div class="artista-card">
                    
                    <% 
                        // Lógica segura: si existe la URL, la usamos. 
                        // Si no empieza con '/', se la agregamos.
                        let imgUrl = artista.imagen_url;
                        if (imgUrl && !imgUrl.startsWith('/')) {
                            imgUrl = '/' + imgUrl;
                        }
                    %>

                    <% if (imgUrl) { %>
                        <img src="<%= imgUrl %>" alt="<%= artista.nombre %>">
                    <% } else { %>
                        <div class="img-placeholder">Imagen no disponible</div>
                    <% } %>
                    
                    <h3><%= artista.nombre %></h3>
                    
                    <p><%= artista.biografia %></p>
                    
                    <a href="/detalle/<%= artista.id %>">Ver más</a>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <p>No se encontraron artistas en la base de datos.</p>
    <% } %>
</main>

<%- include('footer') %>
