<%- include('header') %>

<main class="container">
    <h1>Lista de Artistas</h1>

    <!-- Nota Informativa Movida arriba -->
    <section class="nota-informativa" style="margin-bottom: 30px; padding: 20px; background-color: #0a0a0a; border-left: 5px solid #8b0000; border-radius: 4px;">
        <h3 style="margin-top: 0; color: #ff0000;">Sobre el contenido del archivo</h3>
        <p>
            Esta página contiene archivos DVD's, Blu-rays y VHS ripeados originales tanto para el Visual Kei y J-Rock en general. Nuestro objetivo es preservar la calidad técnica y visual de estos lanzamientos, asegurando que el material llegue a los fans tal como fue concebido por las bandas y sus discográficas. 
        </p>
        <p>
            ¿Tu DVD o material no tiene menú? Es totalmente normal. En los lanzamientos japoneses, si un disco incluye solo video musical, <em>making-of</em> o comentarios, es habitual que <strong>no incluya menú interactivo</strong>. Estas ediciones están diseñadas para reproducción automática (autorun), manteniendo un enfoque minimalista y directo, muy propio de la industria musical en Japón.
        </p>
    </section>

    <!-- Buscador -->
    <div class="search-container" style="text-align: center; margin: 30px 0;">
        <input type="text" id="buscador" placeholder="Buscar artista..." 
               onkeyup="filtrarArtistas()" 
               style="padding: 10px; width: 300px; background: #111; color: #fff; border: 1px solid #444; border-radius: 4px;">
    </div>
    
    <% if (typeof artistas !== 'undefined' && artistas.length > 0) { %>
        <div class="lista-artistas" id="lista-artistas">
            <% artistas.forEach(artista => { %>
                <div class="artista-card">
                    <img src="<%= artista['imagen_url: text'] %>" alt="<%= artista.nombre %>">
                    <h3><%= artista.nombre %></h3>
                    <p><%= artista.biografia %></p>
                    <a href="/detalle/<%= artista.id %>">Ver más</a>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <p>No se encontraron artistas en la base de datos.</p>
    <% } %>
</main>

<%- include('footer') %>
