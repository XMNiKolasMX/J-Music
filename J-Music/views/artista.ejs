<%- include('header') %>

<main class="container">
    <h1>Lista de Artistas</h1>
    
    <% if (typeof artistas !== 'undefined' && artistas.length > 0) { %>
        <!-- Usamos el contenedor que definimos en el CSS -->
        <div class="lista-artistas">
            <% artistas.forEach(artista => { %>
                <div class="artista-card">
                    <!-- 
                         CORRECCIÓN: Se agregó '/img/' antes de la variable 
                         para que coincida con la ruta en la carpeta public.
                         Asegúrate de que el valor en tu base de datos 
                         coincida exactamente con el nombre del archivo.
                    -->
                    <!-- Fíjate bien en la barra "/" inicial -->
<img src="<%= artista.imagen_url.startsWith('/') ? artista.imagen_url : '/' + artista.imagen_url %>" alt="<%= artista.nombre %>">
                    
                    <h3><%= artista.nombre %></h3>
                    
                    <!-- Agregamos la biografía -->
                    <p><%= artista.biografia %></p>
                    
                    <!-- Botón de detalle -->
                    <a href="/detalle/<%= artista.id %>">Ver más</a>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <p>No se encontraron artistas en la base de datos.</p>
    <% } %>
</main>

<%- include('footer') %>
