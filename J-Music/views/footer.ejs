<footer>
    <div class="footer-content">
        <!-- Contenedor del Reproductor Estilo Terminal -->
        <div class="youtube-player-wrapper" id="music-node">
            <div class="player-header">
                <span id="status-icon">●</span> J-MUSIC_STREAMING_NODE_ACTIVE
                <button onclick="togglePlayer()" style="background:transparent; border:none; color:#8b0000; cursor:pointer; font-size:10px; float:right;">[MINIMIZE]</button>
            </div>
            <div class="iframe-container" id="player-box">
                <!-- Se usa videoseries para forzar el modo lista de reproducción -->
                <iframe src="https://www.youtube.com/embed/videoseries?list=PLujyq4vbUunu9zFP9mvTYIkCbbhUZ1-9D&autoplay=0&rel=0&modestbranding=1&theme=dark" 
                        frameborder="0" 
                        allow="autoplay; encrypted-media" 
                        allowfullscreen>
                </iframe>
            </div>
        </div>
        
        <p style="margin-top:20px; font-size: 0.6rem; opacity: 0.7;">© 2026 J-MUSIC ARCHIVE // GLOBAL_ACCESS_GRANTED</p>
    </div>
</footer>

<script>
    // Función para "minimizar" el reproductor y darle más misterio
    function togglePlayer() {
        const box = document.getElementById('player-box');
        const btn = document.querySelector('[onclick="togglePlayer()"]');
        if (box.style.display === 'none') {
            box.style.display = 'block';
            btn.innerText = '[MINIMIZE]';
        } else {
            box.style.display = 'none';
            btn.innerText = '[RESTORE]';
        }
    }
</script>
